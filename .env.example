# ============================================================
# AI Bug Triage System — Environment Variables
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# --- OpenAI API ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- LLM Configuration ---
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# --- Embedding Model ---
EMBEDDING_MODEL_NAME=text-embedding-3-small

# --- Vector Store ---
# Options: "faiss" or "chromadb"
VECTOR_STORE_TYPE=faiss
VECTOR_STORE_PATH=data/vector_store

# --- Duplicate Detection ---
SIMILARITY_THRESHOLD=0.85

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE_PATH=data/temp/app.log

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- LLM Observability (choose one) ---
# Option A: LangSmith (by LangChain)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-your-langsmith-key-here
LANGCHAIN_PROJECT=ai-bug-triage

# Option B: LangFuse (open-source alternative)
# LANGFUSE_PUBLIC_KEY=pk-your-key
# LANGFUSE_SECRET_KEY=sk-your-key
# LANGFUSE_HOST=https://cloud.langfuse.com
